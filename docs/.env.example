# Skytells JS SDK — environment variables
#
# Copy this file to .env in the project root (already gitignored).
# Never commit real keys to source control.
#
# Usage:
#   cp docs/.env.example .env
#   # then fill in your values

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION — required for any API usage
# ─────────────────────────────────────────────────────────────────────────────

# Your Skytells platform API key (starts with sk-).
# Passed as the first argument to Skytells() or SkytellsClient().
# Required for: predictions, chat, responses, embeddings, safety, models.
# Get it at: https://skytells.ai/dashboard/api-keys
SKYTELLS_API_KEY=sk-your-api-key-here

# Orchestrator API key (starts with wfb_). Separate from the platform key.
# Only required when using client.orchestrator (workflows, executions, integrations, etc.).
# Passed as ClientOptions.orchestratorApiKey.
# Get it at: https://learn.skytells.ai/docs/products/orchestrator/api-keys
SKYTELLS_ORCHESTRATOR_KEY=wfb_your-orchestrator-key-here

# ─────────────────────────────────────────────────────────────────────────────
# WEBHOOKS
# ─────────────────────────────────────────────────────────────────────────────

# Enterprise mode webhook secret (from the Skytells dashboard).
# Used when constructing a WebhookListener with mode: 'enterprise'.
# In general mode the SDK uses SKYTELLS_API_KEY as the HMAC secret automatically.
# SKYTELLS_WEBHOOK_SECRET=your-webhook-secret-here

# ─────────────────────────────────────────────────────────────────────────────
# API BASE URLS — override for proxies, staging, or self-hosted instances
# ─────────────────────────────────────────────────────────────────────────────

# Override the Inference API base URL (default: https://api.skytells.ai/v1).
# Pass as ClientOptions.baseUrl. Not read automatically by the SDK — load it yourself:
#   const client = Skytells(process.env.SKYTELLS_API_KEY, {
#     baseUrl: process.env.SKYTELLS_BASE_URL,
#   });
# SKYTELLS_BASE_URL=https://api.skytells.ai/v1

# Override the Orchestrator base URL (default: https://orchestrator.skytells.ai).
# Pass as ClientOptions.orchestratorBaseUrl.
# SKYTELLS_ORCHESTRATOR_BASE_URL=https://orchestrator.skytells.ai

# ─────────────────────────────────────────────────────────────────────────────
# TESTING — model overrides for live / integration test suites
# ─────────────────────────────────────────────────────────────────────────────

# Model used for chat completions tests (npm run test:integration, test:chat-live).
# Default: deepbrain-router
# SKYTELLS_CHAT_MODEL=deepbrain-router

# Model used for Responses API tests (npm run test:chat-live).
# Default: same as SKYTELLS_CHAT_MODEL
# SKYTELLS_RESPONSES_MODEL=gpt-5.3-codex

# Model used for prediction tests (npm run test:prediction-live).
# Default: FLUX.2-pro
# SKYTELLS_PREDICTION_MODEL=FLUX.2-pro

# Model used for embeddings tests (npm run test:integration).
# No default — test is skipped unless this is set to a valid embedding model slug on your account.
# SKYTELLS_EMBEDDING_MODEL=your-embedding-model-slug

# ─────────────────────────────────────────────────────────────────────────────
# DEBUGGING — integration test output
# ─────────────────────────────────────────────────────────────────────────────

# Controls verbose request/response logging in npm run test:integration.
# Set to 0 to suppress console output during integration runs (default: on / any value other than 0).
# Example: SKYTELLS_INTEGRATION_LOG=0 npm run test:integration
# SKYTELLS_INTEGRATION_LOG=1
