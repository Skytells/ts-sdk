{
  "name": "skytells",
  "version": "1.0.5",
  "description": "Official Skytells JavaScript/TypeScript SDK - Edge compatible",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.js",
    "build:types": "tsc --emitDeclarationOnly",
    "test": "jest",
    "test:integration": "jest tests/inference.integration.test.ts --testTimeout=120000 --testPathIgnorePatterns=/node_modules/",
    "test:sdk-live": "jest tests/sdk.live.test.ts --testTimeout=300000 --testPathIgnorePatterns=/node_modules/",
    "test:chat-live": "jest tests/chat-responses.live.test.ts --testTimeout=300000 --testPathIgnorePatterns=/node_modules/ --verbose",
    "test:prediction-live": "jest tests/prediction.live.test.ts --testTimeout=300000 --testPathIgnorePatterns=/node_modules/ --verbose",
    "test:orchestrator-live": "jest tests/orchestrator.live.test.ts --testTimeout=120000 --testPathIgnorePatterns=/node_modules/ --verbose",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix && prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skytells/ts-sdk.git"
  },
  "keywords": [
    "ai",
    "skytells",
    "skytells-ai",
    "skytells-sdk",
    "edge",
    "cloudflare",
    "vercel-edge",
    "netlify-edge"
  ],
  "author": "Skytells, Inc.",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/skytells/ts-sdk/issues"
  },
  "homepage": "https://github.com/skytells/ts-sdk#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.40.0",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.1.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=14"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "prettier --write"
    ]
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  }
}
